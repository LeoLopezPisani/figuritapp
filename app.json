{
  "expo": {
    "name": "FiguritApp 2026",
    "slug": "figuritapp",
    "version": "1.2.1",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "figuritapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "infoPlist": {
        "NSCameraUsageDescription": "Necesitamos la cámara para escanear tus figuritas."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "./assets/images/icon.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "versionCode": 5,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.figuritapp",
      "permissions": ["android.permission.CAMERA"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0f172a",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 180
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Necesitamos la cámara para escanear tus figuritas."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "189179eb-18c0-4e14-b020-b12c5cd3f3ae"
      }
    }
  }
}
